{
	"compilerOptions": {
		"target": "es2022",
		"lib": [
			"es2022"
		],
		"module": "es2022",
		"moduleResolution": "bundler",
		"types": [
			"@cloudflare/workers-types"
		],
		"resolveJsonModule": true,
		"noEmit": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"moduleDetection": "force"
	}
}
